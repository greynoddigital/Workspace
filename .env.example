# Copy this file to .env for local development (or set these as real
# environment variables in your shell / Render dashboard).
#
# GreyNod Workspace stores all application data (projects, settings,
# generated documents) in a private GitHub repository instead of the
# local filesystem. These three variables are required.

# A GitHub Personal Access Token with permission to read/write the
# data repo. A fine-grained PAT scoped to just the Workspace-Data
# repo (Contents: Read and write) is recommended.
GITHUB_TOKEN=

# The GitHub account or organization that owns the data repo.
GITHUB_OWNER=

# The name of the private data repository (e.g. Workspace-Data).
GITHUB_REPO=Workspace-Data

# development | production. Also controls how Puppeteer launches
# Chromium (see src/lib/pdf/pdfGenerator.js) - unrelated to storage.
NODE_ENV=development
